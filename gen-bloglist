<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gold Suresh — Blog Index Updater</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: system-ui, -apple-system, Arial, sans-serif;
      background: #f8fafc;
      color: #111827;
      font-size: 15px;
      line-height: 1.6;
    }
    header {
      background: #0f172a;
      color: #f8fafc;
      padding: 16px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    header h1 { font-size: 1.1rem; font-weight: 700; }
    header span { font-size: 12px; color: #94a3b8; }

    .container { max-width: 780px; margin: 0 auto; padding: 28px 20px; }

    .card {
      background: #fff;
      border: 1px solid #e5e7eb;
      border-radius: 12px;
      padding: 22px 24px;
      margin-bottom: 18px;
    }
    .card-title {
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: #6b7280;
      margin-bottom: 14px;
    }

    .row2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .row3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }

    .field { display: flex; flex-direction: column; gap: 5px; }
    .field label { font-size: 12px; font-weight: 500; color: #374151; }
    .field input {
      height: 42px;
      border: 1.5px solid #d1d5db;
      border-radius: 8px;
      padding: 0 12px;
      font-size: 15px;
      color: #111827;
      background: #f9fafb;
      outline: none;
      transition: border-color 0.15s;
    }
    .field input:focus { border-color: #50FFB1; background: #fff; }
    .field input[readonly] { background: #f0fdf4; color: #065f46; font-weight: 600; cursor: default; }

    .preview-box {
      background: #f8fafc;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      padding: 16px;
      font-family: monospace;
      font-size: 11px;
      color: #374151;
      margin-top: 12px;
      overflow-x: auto;
    }

    .btn {
      width: 100%;
      height: 50px;
      background: #50FFB1;
      border: none;
      border-radius: 10px;
      font-size: 16px;
      font-weight: 700;
      color: #111827;
      cursor: pointer;
      transition: opacity 0.15s, transform 0.1s;
      margin-top: 4px;
    }
    .btn:hover  { opacity: 0.88; }
    .btn:active { transform: scale(0.99); }
    .btn:disabled { opacity: 0.4; cursor: not-allowed; }

    .output-wrap { display: none; }
    .output-wrap.show { display: block; }

    .output-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 10px;
    }
    .output-label {
      font-size: 13px;
      font-weight: 700;
      color: #0f172a;
    }
    .copy-btn {
      padding: 8px 20px;
      background: #0f172a;
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.15s;
    }
    .copy-btn:hover { opacity: 0.85; }
    .copy-btn.copied { background: #065f46; }

    textarea.output-code {
      width: 100%;
      height: 180px;
      font-family: monospace;
      font-size: 11px;
      border: 1.5px solid #d1d5db;
      border-radius: 8px;
      padding: 12px;
      resize: vertical;
      background: #f8fafc;
      color: #111827;
      outline: none;
    }
    textarea.output-code:focus { border-color: #50FFB1; }

    .instruction {
      font-size: 12px;
      color: #6b7280;
      margin-top: 8px;
      line-height: 1.6;
    }
    .instruction strong { color: #111827; }
    .instruction code {
      background: #f1f5f9;
      padding: 2px 6px;
      border-radius: 4px;
      font-family: monospace;
      font-size: 11px;
    }

    .info-badge {
      display: inline-block;
      background: #dbeafe;
      color: #1e40af;
      padding: 6px 12px;
      border-radius: 6px;
      font-size: 12px;
      font-weight: 600;
      margin-top: 8px;
    }

    @media (max-width: 500px) {
      .row2, .row3 { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<header>
  <h1>📝 Gold Suresh — Blog Index Updater</h1>
  <span>Add new posts to /blogs/index.html</span>
</header>

<div class="container">

  <!-- DATE CARD -->
  <div class="card">
    <div class="card-title">📅 Post Date — auto-filled from today</div>
    <div class="row2">
      <div class="field">
        <label>Full Date</label>
        <input type="text" id="dateFull" readonly />
      </div>
      <div class="field">
        <label>Day of Week</label>
        <input type="text" id="dateDay" readonly />
      </div>
    </div>
    <div class="row2" style="margin-top:12px;">
      <div class="field">
        <label>URL Slug</label>
        <input type="text" id="dateSlug" readonly />
      </div>
      <div class="field">
        <label>Display Date (Short)</label>
        <input type="text" id="dateShort" readonly />
      </div>
    </div>
  </div>

  <!-- RATES CARD -->
  <div class="card">
    <div class="card-title">💰 Gold Rates — for card title & description</div>
    <div class="row3">
      <div class="field">
        <label>22K ₹/gram</label>
        <input type="number" id="r22" placeholder="e.g. 14120" />
      </div>
      <div class="field">
        <label>24K ₹/gram</label>
        <input type="number" id="r24" placeholder="e.g. 15404" />
      </div>
      <div class="field">
        <label>18K ₹/gram</label>
        <input type="number" id="r18" placeholder="e.g. 11553" />
      </div>
    </div>
    <p class="instruction" style="margin-top:10px;">These are the same rates you used in the blog post generator — the national India rates.</p>
  </div>

  <!-- PREVIEW -->
  <div class="card">
    <div class="card-title">👁️ Live Preview — how it will look</div>
    <div id="livePreview" class="preview-box">
      <em style="color:#9ca3af;">Fill in the rates above to see preview...</em>
    </div>
  </div>

  <!-- GENERATE -->
  <button class="btn" id="genBtn" onclick="generate()">Generate HTML Snippet</button>

  <!-- OUTPUT -->
  <div class="output-wrap" id="outputWrap" style="margin-top:20px;">
    <div class="card">
      <div class="card-title">✅ Your Blog Index Entry</div>
      <div class="output-header">
        <span class="output-label">HTML to add to blogs/index.html</span>
        <button class="copy-btn" id="copyBtn" onclick="copyHTML()">Copy HTML</button>
      </div>
      <textarea class="output-code" id="outCode" readonly></textarea>
      <p class="instruction">
        <strong>Steps:</strong><br>
        1. Click <strong>Copy HTML</strong> above<br>
        2. Open <code>/blogs/index.html</code> in your editor<br>
        3. Find the <code>&lt;!-- POSTS START HERE --&gt;</code> comment<br>
        4. Paste this snippet as the <strong>first post</strong> (right after the comment)<br>
        5. Save and upload to your server<br>
        <span class="info-badge">💡 Always add new posts at the TOP so latest appears first</span>
      </p>
    </div>
  </div>

</div>

<script>
  // ── Auto-fill date ────────────────────────────────────────────────
  (function() {
    var now = new Date();
    var months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    var monthsShort = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    var days   = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
    var day    = now.getDate();
    var month  = months[now.getMonth()];
    var monthShort = monthsShort[now.getMonth()];
    var year   = now.getFullYear();
    var dow    = days[now.getDay()];
    
    var fullDate = day + ' ' + month + ' ' + year;
    var slug = fullDate.trim().toLowerCase().replace(/\s+/g, '-');
    var shortDate = day + ' ' + monthShort + ' ' + year;
    
    document.getElementById('dateFull').value = fullDate;
    document.getElementById('dateDay').value = dow;
    document.getElementById('dateSlug').value = slug;
    document.getElementById('dateShort').value = shortDate;
  })();

  // ── Helpers ───────────────────────────────────────────────────────
  function fmt(n) {
    if (!n) return '—';
    return Number(n).toLocaleString('en-IN');
  }

  // ── Live Preview ──────────────────────────────────────────────────
  function updatePreview() {
    var r22 = document.getElementById('r22').value;
    var r24 = document.getElementById('r24').value;
    var r18 = document.getElementById('r18').value;
    var dateShort = document.getElementById('dateShort').value;
    var slug = document.getElementById('dateSlug').value;
    var preview = document.getElementById('livePreview');

    if (!r22 || !r24 || !r18) {
      preview.innerHTML = '<em style="color:#9ca3af;">Fill in the rates above to see preview...</em>';
      return;
    }

    var html = `<div style="background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:16px;max-width:400px;">
  <div style="font-size:11px;color:#6b7280;margin-bottom:6px;">${dateShort}</div>
  <div style="font-weight:700;color:#111827;font-size:13px;margin-bottom:8px;line-height:1.3;">
    Today's Gold Rate in India — ${dateShort}<br>
    22K ₹${fmt(r22)}/g · 24K ₹${fmt(r24)}/g · 18K ₹${fmt(r18)}/g
  </div>
  <div style="font-size:11px;color:#6b7280;margin-bottom:10px;">
    Daily gold rate update for India with city-wise rates...
  </div>
  <a href="gold-rate-today-${slug}" style="display:inline-block;background:#50FFB1;padding:8px 16px;border-radius:6px;font-size:12px;font-weight:700;color:#111827;text-decoration:none;">
    Read Full Post →
  </a>
</div>`;

    preview.innerHTML = html;
  }

  // Listen to input changes
  ['r22', 'r24', 'r18'].forEach(function(id) {
    document.getElementById(id).addEventListener('input', updatePreview);
  });

  // ── Generate ──────────────────────────────────────────────────────
  function generate() {
    var dateFull = document.getElementById('dateFull').value.trim();
    var dateShort = document.getElementById('dateShort').value.trim();
    var slug = document.getElementById('dateSlug').value.trim();
    var r22 = +document.getElementById('r22').value;
    var r24 = +document.getElementById('r24').value;
    var r18 = +document.getElementById('r18').value;

    if (!r22 || !r24 || !r18) {
      alert('Please enter all three gold rates (22K, 24K, 18K).');
      return;
    }

    // Generate the HTML snippet for index.html
    var snippet = `    <article class="post-card">
      <div class="post-date">${dateShort}</div>
      <h2 class="post-title">
        <a href="gold-rate-today-${slug}">
          Today's Gold Rate in India — ${dateShort}<br>
          22K ₹${fmt(r22)}/g · 24K ₹${fmt(r24)}/g · 18K ₹${fmt(r18)}/g
        </a>
      </h2>
      <p class="post-excerpt">
        Daily gold rate update for India with city-wise rates for Chennai, Mumbai, Delhi, Bangalore, Hyderabad and 120+ cities. Updated this morning after IBJA benchmark.
      </p>
      <a href="gold-rate-today-${slug}" class="read-more">Read Full Post →</a>
    </article>
`;

    document.getElementById('outCode').value = snippet;
    document.getElementById('outputWrap').classList.add('show');
    document.getElementById('outputWrap').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // ── Copy ──────────────────────────────────────────────────────────
  function copyHTML() {
    var ta = document.getElementById('outCode');
    ta.select();
    document.execCommand('copy');
    var btn = document.getElementById('copyBtn');
    btn.textContent = '✓ Copied!';
    btn.classList.add('copied');
    setTimeout(function() {
      btn.textContent = 'Copy HTML';
      btn.classList.remove('copied');
    }, 2500);
  }
</script>

</body>
</html>
